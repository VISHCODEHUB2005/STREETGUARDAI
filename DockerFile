# This is the base image with Python 3.9
FROM python:3.9-slim

# Set the working directory inside the container
WORKDIR /app

# Copy requirements.txt from your computer into the container
COPY requirements.txt .

# Install all Python packages listed in requirements.txt
RUN pip install --no-cache-dir -r requirements.txt

# Copy ALL your project files into the container
COPY . .

# Tell Docker what port your app uses (change 8000 if different)
EXPOSE 8000

# This command runs when the container starts
CMD ["python", "main.py"]
